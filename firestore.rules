rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 본인 문서만 read/write 허용
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // 프로필 (싱글톤)
      match /profile/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // 계산기 상태 (stats 등) — calcId당 한 문서
      match /calculatorState/{calcId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null
          && request.auth.uid == uid
          && request.resource.size() < 100 * 1024;
      }

      // 프리셋 — 이름 50자 이하
      match /presets/{presetId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 50
          && request.resource.size() < 100 * 1024;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      // 커스텀 데이터 (companion/equipment/costume/skill/card)
      match /customData/{type}/items/{itemId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.label is string
          && request.resource.data.label.size() <= 50
          && request.resource.size() < 100 * 1024;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      // 저장된 빌드 (Phase 12+ 백로그)
      match /savedBuilds/{buildId} {
        allow read, write: if request.auth != null
          && request.auth.uid == uid
          && request.resource.size() < 100 * 1024;
      }
    }

    // 그 외 모든 경로 거부
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
