rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isSmall() {
      return request.resource.size < 102400; // 100 KB
    }

    function hasValidName() {
      return !('name' in request.resource.data) ||
        (request.resource.data.name is string &&
         request.resource.data.name.size() <= 50);
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /profile/{doc} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && isSmall();
      }

      match /calculatorState/{calcId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && isSmall();
      }

      match /presets/{presetId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isSmall() && hasValidName();
        allow delete: if isOwner(uid);
      }

      match /customData/{type}/items/{itemId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isSmall() && hasValidName();
        allow delete: if isOwner(uid);
      }
    }

    // 그 외 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
